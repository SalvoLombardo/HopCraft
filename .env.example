# ================================
# DATABASE (PostgreSQL)
# ================================
DATABASE_URL=postgresql+asyncpg://hopcraft:password@db:5432/hopcraft
DB_PASSWORD=your_secure_password_here

# ================================
# REDIS
# ================================
REDIS_URL=redis://redis:6379/0

# ================================
# FLIGHT PROVIDERS — cascade SerpAPI → Amadeus
# ================================
#
# FLIGHT_PROVIDER — controlla l'ordine della cascade.
#   cascade  → automatico per quota residua Redis: SerpAPI → Amadeus (default)
#   serpapi  → SerpAPI in testa, Amadeus come fallback
#   amadeus  → Amadeus in testa, SerpAPI come fallback
#              consigliato in sviluppo: Amadeus ha 2000 req/mese vs 250 di SerpAPI
FLIGHT_PROVIDER=cascade

# SerpAPI — Google Flights (250 req/mese gratis)
# Registrazione: https://serpapi.com — copre Wizz Air, easyJet (Ryanair parziale)
# Nessuna carta di credito richiesta.
SERPAPI_API_KEY=your_serpapi_api_key_here

# Amadeus Self-Service API (2.000 req/mese gratis)
# Registrazione: https://developers.amadeus.com/ — nessuna carta richiesta
# Nota: tier gratuito copre solo major carriers, NO low-cost EU.
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# ================================
# LLM PROVIDER
# Opzioni: gemini | groq | mistral
# Con fallback automatico in quest'ordine se il primario fallisce
# Nessuno dei tre richiede carta di credito per il tier gratuito
# ================================
LLM_PROVIDER=gemini

# Google Gemini 2.5 Flash (primario)
# API key su: https://aistudio.google.com — generata istantaneamente, no carta
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — Llama 3.3 70B (fallback veloce, >300 token/sec)
# Registrazione: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Mistral — La Plateforme (fallback volume, 1B token/mese gratis)
# Registrazione: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# ================================
# APP
# ================================
APP_ENV=development
CACHE_TTL_HOURS=6
MAX_AIRPORTS_SEARCH=300
